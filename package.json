{
  "name": "youtube-watch-party-pro",
  "version": "1.0.0",
  "description": "Real-time YouTube Watch Party with Socket.IO rooms, role-based access control, chat and AI help assistant.",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
    "client": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "node server.js"
  },
  "keywords": ["youtube", "watch-party", "socket.io", "websocket", "react", "express", "roles"],
  "author": "Rewant Anand",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest",
    "express": "latest",
    "socket.io": "latest",
    "socket.io-client": "latest",
    "cors": "latest",
    "nanoid": "^3.3.7"
  },
  "devDependencies": {
    "concurrently": "latest",
    "nodemon": "latest"
  }
}
